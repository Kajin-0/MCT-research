  -0.002576718528658 -0.002576718528658 0 1.0 ! 05 -001_h_over_2
  0.005950676544586 0.005950676544586 0.005950676544586 1.0 ! 06 +111_h
  -0.005950676544586 -0.005950676544586 -0.005950676544586 1.0 ! 07 -111_h
  0.002975338272293 0.002975338272293 0.002975338272293 1.0 ! 08 +111_h_over_2
  -0.002975338272293 -0.002975338272293 -0.002975338272293 1.0 ! 09 -111_h_over_2
  0.003644030289646 0.003644030289646 0.007288060579292 1.0 ! 10 +110_h
