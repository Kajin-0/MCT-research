# CdTe nonadiabatic AHC EPH-driver fragment
#
# This is NOT a standalone ABINIT input. Attach it to a validated, fully
# relativistic GS/DFPT workflow that has produced compatible WFK, DDB and DVDB
# files. Replace every @PLACEHOLDER@ and verify against the installed ABINIT
# release before execution.

optdriver 7
eph_task 4

# Nonadiabatic AHC. The adiabatic control run sets this to 0.
eph_ahc_type 1

# Lorentzian integration for the full electron self-energy.
eph_intmeth 1
zcut @ZCUT_HA@

# Exact one-temperature job. Run separately for 0, 77, 150, 225 and 300 K.
tmesh @TEMPERATURE_K@ 1 1

# Coarse q mesh encoded in the merged DDB and fine interpolation mesh.
ddb_ngqpt @NQ_COARSE@ @NQ_COARSE@ @NQ_COARSE@
eph_ngqpt_fine @NQ_FINE@ @NQ_FINE@ @NQ_FINE@

# Polar long-range interpolation is enabled by default through dvdb_add_lr=1.
# Keep a deliberate off-control run for convergence diagnostics.
dvdb_add_lr 1

# Explicit Fröhlich micro-zone correction. Converge this angular mesh and run
# a zero-valued control to quantify the correction.
eph_frohl_ntheta @FROHLICH_NTHETA@

# Empty-state versus Sternheimer study. The primary nonadiabatic calculation
# should not silently replace the dynamical denominators with the Sternheimer
# adiabatic approximation.
eph_stern 0
nband @NBAND@

# Target states and evaluation k points must include the Kane subspace and the
# mixed directions required to identify gamma3. Supply nkptgw/kptgw/bdgw in the
# surrounding validated input or workflow.

# External files generated by the preceding stages.
getwfk_filepath "@WFK_PATH@"
getddb_filepath "@DDB_PATH@"
getdvdb_filepath "@DVDB_PATH@"

# Restart an interrupted compatible self-energy calculation when desired.
eph_restart @EPH_RESTART@

# Record in the convergence ledger:
# code version, pseudopotential SHA-256, ecut, k/q meshes, nband, zcut,
# eph_frohl_ntheta, volume, temperature, and all input/output hashes.
